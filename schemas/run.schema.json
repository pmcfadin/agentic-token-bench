{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Run Record",
  "description": "Schema for benchmark run records.",
  "type": "object",
  "required": [
    "run_id", "task_id", "family", "variant", "agent_id",
    "adapter_version", "repo_commit", "status", "validity",
    "validation_status"
  ],
  "properties": {
    "run_id": { "type": "string" },
    "task_id": { "type": "string" },
    "family": { "type": "string" },
    "variant": { "type": "string", "enum": ["baseline", "tool_variant"] },
    "agent_id": { "type": "string" },
    "adapter_version": { "type": "string" },
    "repo_commit": { "type": "string" },
    "status": { "type": "string", "enum": ["passed", "failed", "error"] },
    "validity": { "type": "string", "enum": ["valid", "invalid"] },
    "reported_input_tokens": { "type": ["integer", "null"] },
    "reported_output_tokens": { "type": ["integer", "null"] },
    "reported_total_tokens": { "type": ["integer", "null"] },
    "elapsed_seconds": { "type": ["number", "null"] },
    "repair_iterations": { "type": "integer" },
    "validation_status": { "type": "string", "enum": ["passed", "failed", "skipped"] },
    "files_changed": { "type": "integer" },
    "diff_size": { "type": "integer" },
    "artifact_dir": { "type": "string" },
    "started_at": { "type": ["string", "null"], "format": "date-time" },
    "finished_at": { "type": ["string", "null"], "format": "date-time" },
    "track": { "type": "string", "enum": ["legacy_agent", "tool_only", "quality_eval"] },
    "task_version": { "type": ["string", "null"] },
    "phase_records": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "track", "status", "validation_status"],
        "properties": {
          "name": { "type": "string" },
          "track": { "type": "string", "enum": ["legacy_agent", "tool_only", "quality_eval"] },
          "status": { "type": "string", "enum": ["passed", "failed", "error"] },
          "started_at": { "type": ["string", "null"], "format": "date-time" },
          "finished_at": { "type": ["string", "null"], "format": "date-time" },
          "validation_status": { "type": "string", "enum": ["passed", "failed", "skipped"] },
          "notes": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "tool_metrics": {
      "type": ["object", "null"],
      "properties": {
        "raw_bytes": { "type": ["integer", "null"] },
        "reduced_bytes": { "type": ["integer", "null"] },
        "raw_tokens": { "type": ["integer", "null"] },
        "reduced_tokens": { "type": ["integer", "null"] },
        "reduction_ratio": { "type": ["number", "null"] },
        "deterministic_valid": { "type": ["boolean", "null"] },
        "deterministic_check_count": { "type": "integer" }
      }
    },
    "quality_metrics": {
      "type": ["object", "null"],
      "properties": {
        "raw_quality_score": { "type": ["number", "null"] },
        "reduced_quality_score": { "type": ["number", "null"] },
        "quality_delta": { "type": ["number", "null"] },
        "llm_call_count_small": { "type": "integer" },
        "llm_call_count_expensive": { "type": "integer" },
        "escalation_reason": { "type": ["string", "null"] },
        "evaluator_model_class": { "type": "string", "enum": ["none", "small", "expensive"] }
      }
    }
  }
}
